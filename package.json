{
  "name": "@senwong/prompt-vault",
  "version": "1.0.0",
  "description": "A calm, developer-oriented prompt vault — hybrid search, multi-format copy, and zero-click ingestion of your local Codex & OpenCode history. Runs as a local app from the CLI.",
  "type": "module",
  "bin": {
    "prompt-vault": "bin/prompt-vault.mjs"
  },
  "files": [
    "bin",
    "server",
    "prompt-vault/Prompt Vault.html"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node bin/prompt-vault.mjs",
    "dev": "node build.mjs && node bin/prompt-vault.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "keywords": [
    "prompt",
    "prompts",
    "prompt-manager",
    "cli",
    "codex",
    "opencode",
    "search"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
